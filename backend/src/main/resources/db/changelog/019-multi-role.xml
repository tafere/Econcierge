<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="019-1-create-staff-roles-table" author="econcierge">
        <createTable tableName="staff_roles">
            <column name="staff_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_staff_roles_staff"
                             references="staff(id)"
                             deleteCascade="true"/>
            </column>
            <column name="role" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="staff_roles" columnNames="staff_id, role" constraintName="pk_staff_roles"/>
    </changeSet>

    <changeSet id="019-2-migrate-existing-roles" author="econcierge">
        <sql>
            INSERT INTO staff_roles (staff_id, role)
            SELECT id, role FROM staff
            WHERE role IS NOT NULL;
        </sql>
    </changeSet>

    <changeSet id="019-3-drop-role-column" author="econcierge">
        <dropColumn tableName="staff" columnName="role"/>
    </changeSet>

</databaseChangeLog>
