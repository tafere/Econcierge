<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add scheduling fields to request_items -->
    <changeSet id="011-1" author="econcierge">
        <addColumn tableName="request_items">
            <column name="schedulable" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="slot_interval_mins" type="INT" defaultValueNumeric="30">
                <constraints nullable="false"/>
            </column>
            <column name="capacity" type="INT" defaultValueNumeric="15">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- Bookings table -->
    <changeSet id="011-2" author="econcierge">
        <createTable tableName="bookings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="item_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="room_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="slot_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="guest_count" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(500)"/>
            <column name="status" type="VARCHAR(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
